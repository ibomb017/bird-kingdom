# Bird Kingdom Swift 后端环境配置

# 服务器配置
HOST=0.0.0.0
PORT=8080

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_NAME=bird_kingdom
DB_USE_SSL=false

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 开发模式（生产环境必须设为false）
APP_DEV_MODE=false

# 阿里云 OSS 配置
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET=birdkingdom

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=义乌市侨吧贸易
ALIYUN_SMS_TEMPLATE_CODE=SMS_499015325
ALIYUN_SMS_REGION_ID=cn-shanghai

# Apple App Store API 配置（用于 VIP 收据验证）
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_BUNDLE_ID=com.birdkingdom.app
APPLE_USE_SANDBOX=true

# SMS Proxy 配置
# SMS_PROXY_URL 指向 SMS Proxy 服务地址（生产环境通常是同一服务器的 8082 端口）
SMS_PROXY_URL=http://127.0.0.1:8082/internal/sms/send
# SMS_PROXY_API_KEY 是 Swift 后端和 SMS Proxy 之间的认证密钥，两边必须相同
SMS_PROXY_API_KEY=birdkingdom-sms-proxy-2026-production-key
