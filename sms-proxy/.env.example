# 短信代理服务环境变量配置示例
# 复制此文件为 .env 并填入实际值

# SMS代理API密钥（用于新加坡服务器调用认证）
# 请生成一个安全的随机字符串
SMS_PROXY_API_KEY=your-secure-api-key-here

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=义乌市侨吧贸易
ALIYUN_SMS_TEMPLATE_CODE=SMS_499015325
ALIYUN_SMS_REGION_ID=cn-shanghai
